{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Code-vs-DTS human decision batch",
  "type": "object",
  "properties": {
    "schema_version": {
      "const": 1
    },
    "decision_set_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]{0,79}$"
    },
    "generated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "applied_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "register_discovery_run": {
      "type": "string"
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "gap_id": {
            "type": "string",
            "pattern": "^GAP-[0-9]{3,}$"
          },
          "gap_title": {
            "type": "string",
            "minLength": 1
          },
          "gap_fingerprint": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "decision_required": {
            "type": "string",
            "minLength": 1
          },
          "alternatives_considered": {
            "type": "string",
            "minLength": 1
          },
          "approved": {
            "const": true
          },
          "authority": {
            "type": "string",
            "minLength": 1
          },
          "decision_date": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
          },
          "decision": {
            "type": "string",
            "minLength": 1
          },
          "constraints": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "implementation_direction": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "migration": {
            "type": "string",
            "minLength": 1
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "requires_fresh_discovery": {
            "type": "boolean"
          }
        },
        "required": [
          "gap_id",
          "gap_title",
          "gap_fingerprint",
          "decision_required",
          "alternatives_considered",
          "approved",
          "authority",
          "decision_date",
          "decision",
          "constraints",
          "implementation_direction",
          "migration",
          "acceptance_criteria",
          "requires_fresh_discovery"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "schema_version",
    "decision_set_id",
    "generated_at_utc",
    "register_discovery_run",
    "decisions"
  ],
  "additionalProperties": false
}
