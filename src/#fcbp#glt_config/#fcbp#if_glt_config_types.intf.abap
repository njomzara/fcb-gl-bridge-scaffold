           netting_allowed        TYPE abap_bool,
           source_hash_version    TYPE char20,
           changed_by             TYPE syuname,
           changed_at             TYPE utclong,
         END OF ty_aggregation_policy.

  TYPES: BEGIN OF ty_aggregation_field,
           aggregation_profile_id TYPE char20,
           version                TYPE i,
           field_sequence         TYPE i,
           field_name             TYPE char40,
           required_flag          TYPE abap_bool,
           normalize_rule         TYPE char30,
