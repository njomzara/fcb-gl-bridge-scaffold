           changed_by             TYPE syuname,
           changed_at             TYPE utclong,
           activated_by           TYPE syuname,
           activated_at           TYPE utclong,
         END OF ty_target_profile.
  TYPES tt_target_profile TYPE STANDARD TABLE OF ty_target_profile WITH EMPTY KEY.

