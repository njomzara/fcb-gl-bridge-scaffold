           resolution_time   TYPE tims,
           requested_by      TYPE char40,
           correlation_id    TYPE /fcbp/if_glt_types=>ty_correlation_id,
         END OF ty_routing_scope.

  TYPES: BEGIN OF ty_target_profile,
           target_id              TYPE char20,
           target_type            TYPE char20,
           adapter_type           TYPE char20,
           destination_alias      TYPE char40,
           transfer_mode          TYPE char10,
           confirmation_mode      TYPE char20,
           retry_policy_id        TYPE char20,
           aggregation_profile_id TYPE char20,
           split_profile_id       TYPE char20,
           validation_profile_id  TYPE char20,
           mapping_policy_id      TYPE char20,
           throttle_policy_id     TYPE char20,
