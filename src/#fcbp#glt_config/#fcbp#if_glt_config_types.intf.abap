"! Configuration Layer DTOs and constants for target profiles, policy families, and policy-context evidence.
INTERFACE /fcbp/if_glt_config_types PUBLIC.

  CONSTANTS:
    BEGIN OF c_lifecycle_state,
      draft          TYPE char20 VALUE 'DRAFT',
      inactive       TYPE char20 VALUE 'INACTIVE',
      pending_health TYPE char20 VALUE 'PENDING_HEALTH',
      health_failed  TYPE char20 VALUE 'HEALTH_FAILED',
      active         TYPE char20 VALUE 'ACTIVE',
      blocked        TYPE char20 VALUE 'BLOCKED',
      superseded     TYPE char20 VALUE 'SUPERSEDED',
      expired        TYPE char20 VALUE 'EXPIRED',
      deactivated    TYPE char20 VALUE 'DEACTIVATED',
    END OF c_lifecycle_state.

  CONSTANTS:
    BEGIN OF c_health_state,
      ok      TYPE char12 VALUE 'OK',
      warning TYPE char12 VALUE 'WARNING',
      blocked TYPE char12 VALUE 'BLOCKED',
      unknown TYPE char12 VALUE 'UNKNOWN',
    END OF c_health_state.

  CONSTANTS:
    BEGIN OF c_target_type,
      s4_public_cloud  TYPE char20 VALUE 'S4_PUBLIC_CLOUD',
      s4_private_cloud TYPE char20 VALUE 'S4_PRIVATE_CLOUD',
      integration_suite TYPE char20 VALUE 'INTEGRATION_SUITE',
      on_prem          TYPE char20 VALUE 'ON_PREM',
      mock             TYPE char20 VALUE 'MOCK',
    END OF c_target_type.

  CONSTANTS:
    BEGIN OF c_object_type,
      target_profile      TYPE char30 VALUE 'TARGET_PROFILE',
      retry_policy        TYPE char30 VALUE 'RETRY_POLICY',
      aggregation_policy  TYPE char30 VALUE 'AGGREGATION_POLICY',
      aggregation_field   TYPE char30 VALUE 'AGGREGATION_FIELD',
      split_policy        TYPE char30 VALUE 'SPLIT_POLICY',
      validation_rule     TYPE char30 VALUE 'VALIDATION_RULE',
      mapping_rule        TYPE char30 VALUE 'MAPPING_RULE',
      throttle_policy     TYPE char30 VALUE 'THROTTLE_POLICY',
      confirmation_policy TYPE char30 VALUE 'CONFIRMATION_POLICY',
      policy_context      TYPE char30 VALUE 'POLICY_CONTEXT',
    END OF c_object_type.

  CONSTANTS:
    BEGIN OF c_resolution_reason,
      missing      TYPE char40 VALUE 'CONFIG_MISSING',
      inactive     TYPE char40 VALUE 'CONFIG_INACTIVE',
      expired      TYPE char40 VALUE 'CONFIG_EXPIRED',
      ambiguous    TYPE char40 VALUE 'CONFIG_AMBIGUOUS',
      unsupported  TYPE char40 VALUE 'CONFIG_UNSUPPORTED',
      unhealthy    TYPE char40 VALUE 'CONFIG_UNHEALTHY',
      inconsistent TYPE char40 VALUE 'CONFIG_INCONSISTENT',
      auth         TYPE char40 VALUE 'CONFIG_AUTHORIZATION',
    END OF c_resolution_reason.

  TYPES ty_policy_context_id TYPE char32.
  TYPES ty_health_run_id TYPE char32.

  TYPES: BEGIN OF ty_routing_scope,
           transfer_id       TYPE /fcbp/if_glt_types=>ty_transfer_id,
           transfer_type     TYPE char20,
