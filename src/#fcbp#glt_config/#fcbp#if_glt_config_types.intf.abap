           poll_before_retry      TYPE abap_bool,
           operator_action_rule   TYPE char30,
           changed_by             TYPE syuname,
           changed_at             TYPE utclong,
         END OF ty_retry_policy.

  TYPES: BEGIN OF ty_aggregation_policy,
           aggregation_profile_id TYPE char20,
           version                TYPE i,
           active_flag            TYPE abap_bool,
           lifecycle_state        TYPE char20,
