           changed_by             TYPE syuname,
           changed_at             TYPE utclong,
         END OF ty_mapping_rule.
  TYPES tt_mapping_rule TYPE STANDARD TABLE OF ty_mapping_rule WITH EMPTY KEY.

  TYPES: BEGIN OF ty_throttle_policy,
           throttle_policy_id     TYPE char20,
           version                TYPE i,
           active_flag            TYPE abap_bool,
           lifecycle_state        TYPE char20,
           config_hash            TYPE char64,
           max_parallel           TYPE i,
