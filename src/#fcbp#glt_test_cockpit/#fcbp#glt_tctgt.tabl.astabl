"! /FCBP/GLT_TCTGT - mock target document tree nodes for a cockpit run.
@EndUserText.label : 'GLT Test Cockpit Mock Target Tree'
@AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
@AbapCatalog.tableCategory : #TRANSPARENT
@AbapCatalog.deliveryClass : #A
@AbapCatalog.dataMaintenance : #RESTRICTED
define table /fcbp/glt_tctgt {
  key client             : abap.clnt not null;
  key run_id             : abap.char(32) not null;
  key node_id            : abap.char(40) not null;
  parent_node_id         : abap.char(40);
  sibling_order          : abap.int4 not null;
  node_type              : abap.char(20) not null;
  drill_state            : abap.char(10);
  target_doc_no          : abap.char(30);
  target_line_no         : abap.numc(6);
  transfer_id            : abap.char(32);
  package_id             : abap.char(32);
  outdoc_id              : abap.char(32);
  line_id                : abap.char(32);
  trace_id               : abap.char(32);
  source_reference       : abap.char(50);
  source_doc_no          : abap.char(20);
  source_item_no         : abap.numc(6);
  gl_account             : abap.char(10);
  debit_credit           : abap.char(1);
  amount                 : abap.dec(23,2);
  contribution_amount    : abap.dec(23,2);
  contribution_ratio     : abap.dec(15,6);
  currency               : abap.cuky;
  target_status          : abap.char(20);
  node_text              : abap.char(120);
  created_at             : utclong;
}
