"! /FCBP/GLT_TCRUN - test cockpit run header and result rollup.
@EndUserText.label : 'GLT Test Cockpit Run'
@AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
@AbapCatalog.tableCategory : #TRANSPARENT
@AbapCatalog.deliveryClass : #A
@AbapCatalog.dataMaintenance : #RESTRICTED
define table /fcbp/glt_tcrun {
  key client             : abap.clnt not null;
  key run_id             : abap.char(32) not null;
  scenario_id            : abap.char(30) not null;
  command_id             : abap.char(30) not null;
  command_text           : abap.char(120);
  run_status             : abap.char(20) not null;
  status_criticality     : abap.int4 not null;
  status_text            : abap.char(120);
  transfer_id            : abap.char(32);
  package_id             : abap.char(32);
  outbox_id              : abap.char(32);
  policy_context_id      : abap.char(32);
  validation_run_id      : abap.char(32);
  mapping_run_id         : abap.char(32);
  target_doc_no          : abap.char(30);
  source_reference       : abap.char(50);
  source_doc_no          : abap.char(20);
  company_code           : abap.char(4);
  target_id              : abap.char(20);
  final_status           : abap.char(24);
  outbox_status          : abap.char(12);
  validation_status      : abap.char(20);
  mapping_status         : abap.char(20);
  seeded_source_count    : abap.int4;
  transfer_item_count    : abap.int4;
  work_item_count        : abap.int4;
  canonical_line_count   : abap.int4;
  target_tree_node_count : abap.int4;
  created_by             : abap.char(12) not null;
  started_at             : utclong not null;
  finished_at            : utclong;
  duration_ms            : abap.int4;
  message_text           : abap.char(220);
}
