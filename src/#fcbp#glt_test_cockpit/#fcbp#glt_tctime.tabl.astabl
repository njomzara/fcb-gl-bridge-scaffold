"! /FCBP/GLT_TCTIME - combined status/audit timeline for a cockpit run.
@EndUserText.label : 'GLT Test Cockpit Timeline'
@AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
@AbapCatalog.tableCategory : #TRANSPARENT
@AbapCatalog.deliveryClass : #A
@AbapCatalog.dataMaintenance : #RESTRICTED
define table /fcbp/glt_tctime {
  key client             : abap.clnt not null;
  key run_id             : abap.char(32) not null;
  key event_seq          : abap.int4 not null;
  timeline_kind          : abap.char(10) not null;
  transfer_id            : abap.char(32);
  event_type             : abap.char(30);
  event_subtype          : abap.char(30);
  old_status_code        : abap.char(24);
  new_status_code        : abap.char(24);
  reason_code            : abap.char(30);
  actor_type             : abap.char(12);
  actor_id               : abap.char(40);
  correlation_id         : abap.char(64);
  evidence_ref           : abap.char(255);
  criticality            : abap.int4;
  message_text           : abap.char(220);
  created_at             : utclong;
}
