"! /FCBP/GLT_TCSD - seeded source rows captured for a cockpit run.
@EndUserText.label : 'GLT Test Cockpit Seeded Source'
@AbapCatalog.enhancement.category : #NOT_EXTENSIBLE
@AbapCatalog.tableCategory : #TRANSPARENT
@AbapCatalog.deliveryClass : #A
@AbapCatalog.dataMaintenance : #RESTRICTED
define table /fcbp/glt_tcsd {
  key client             : abap.clnt not null;
  key run_id             : abap.char(32) not null;
  key source_seq         : abap.int4 not null;
  source_type            : abap.char(20);
  source_reference       : abap.char(50);
  source_doc_no          : abap.char(20);
  source_item_no         : abap.numc(6);
  reconciliation_key     : abap.char(32);
  company_code           : abap.char(4);
  gl_account             : abap.char(10);
  debit_credit           : abap.char(1);
  amount                 : abap.dec(23,2);
  currency               : abap.cuky;
  profit_center          : abap.char(10);
  segment                : abap.char(10);
  cost_center            : abap.char(10);
  assignment             : abap.char(18);
  item_text              : abap.char(50);
  source_hash            : abap.char(64);
  line_hash              : abap.char(64);
  captured_at            : utclong;
}
